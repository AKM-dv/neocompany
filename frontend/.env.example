# Copy to .env for local dev (optional). Production uses `.env.production` / host env.

# Full URL of Flask API (no trailing slash). Live: https://b.neocompany.neighshopglobal.com
# Leave empty when using Vite proxy (see vite.config.js) against localhost.
VITE_API_URL=

# GitHub Pages project site only, e.g. /repo-name/. Normal custom domain:
VITE_BASE_PATH=/

